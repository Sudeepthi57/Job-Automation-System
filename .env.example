# Copy this file to .env and fill in your values

# OpenAI API Key — get from platform.openai.com
OPENAI_API_KEY=sk-...

# AI model to use (gpt-4o-mini is cheap and fast, gpt-4o is better quality)
OPENAI_MODEL=gpt-4o-mini

# Minimum relevance score to keep a job (1-10)
MIN_RELEVANCE_SCORE=6

# What role are you targeting?
TARGET_ROLE=AI Engineer

# Your key skills (used for AI scoring)
TARGET_SKILLS=Python, FastAPI, LLM, Machine Learning, Backend
